# ========================================
# Network Management - Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- General ---
SECRET_KEY=change-this-to-a-random-secret
APP_ENV=production
CORS_ORIGINS=http://localhost:5173

# --- API Auth/Roles ---
# Format: token:role,token:role (roles: admin|operator|viewer)
API_AUTH_ENABLED=true
API_AUTH_TOKENS=admin-token:admin,operator-token:operator,viewer-token:viewer
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_INTROSPECT_URL=http://localhost:5003/api/auth/introspect
AUTH_INTROSPECT_TIMEOUT=3

# --- SSH Terminal (Port 8443) ---
SESSION_SECRET=change-this-to-a-random-secret
SSH_TIMEOUT=30000
SSH_KEEPALIVE_INTERVAL=10000

# --- SNMP ---
SNMP_COMMUNITY=your_snmp_community_string

# --- SMTP (for scheduled backup email reports) ---
SMTP_SERVER=localhost
SMTP_PORT=25
SMTP_FROM=config-backup@example.com
SMTP_TO=admin@example.com

# --- Server ---
SERVER_USER=your_username
SERVER_IP=your_server_ip

# --- Backup API ---
BACKUP_API_URL=http://localhost:5003
DISCOVERY_API_URL=http://localhost:5004/api/discover

# --- Network Infrastructure (used in Jinja2 templates) ---
# DNS_SERVER=your_dns_server
# DNS_DOMAIN=example.com
# NTP_SERVER=your_ntp_server
# LOG_HOST=your_syslog_server
